[Unit]
Description=One Piece TCG Assistant
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/optcg-assistant/backend
ExecStart=/home/pi/optcg-assistant/backend/.venv/bin/uvicorn app.presentation.main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
